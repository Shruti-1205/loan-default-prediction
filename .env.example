# Copy this file to .env and fill in values before running generate_model.py
# or any MLflow experiment tracking code.

MLFLOW_TRACKING_URI=https://dagshub.com/<user>/<repo>.mlflow
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=

# Streamlit frontend configuration
# Set USE_API=true to call the FastAPI backend instead of the in-process model.
USE_API=false
API_URL=http://127.0.0.1:8000
